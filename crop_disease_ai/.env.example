# =============================================================================
# Required: OpenWeather API Key (free tier: 60 calls/min)
# Get yours at: https://openweathermap.org/api
# =============================================================================
OPENWEATHER_API_KEY=your_openweather_api_key_here

# =============================================================================
# Optional: OpenAI API Key (for AI Assistant features)
# Get yours at: https://platform.openai.com/api-keys
# =============================================================================
OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# Optional: Gemini API Key (for AI Assistant features)
# Get yours at: https://aistudio.google.com/app/apikey
# =============================================================================
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=AI-Driven Crop Disease Prediction System
APP_VERSION=1.0.0
DEBUG=False

# =============================================================================
# Model Settings (paths relative to crop_disease_ai/)
# =============================================================================
MODEL_PATH=models/plant_disease_model.h5
CLASS_INDICES_PATH=models/class_indices.npy
IMG_SIZE=224
CONFIDENCE_THRESHOLD=0.6

# =============================================================================
# Database
# =============================================================================
DB_PATH=database/crop_disease_ai.db

# =============================================================================
# Streamlit Settings
# =============================================================================
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_MAX_UPLOAD_SIZE=10
